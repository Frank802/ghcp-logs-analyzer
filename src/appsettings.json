{
  "GitHub": {
    "Token": "YOUR_GITHUB_TOKEN",
    "TargetRepository": "owner/repo",
    "Model": "claude-sonnet-4.6"
  },
  "LogAnalysis": {
    "Source": "FileSystem",
    "MinLevel": "Error",
    "MaxConcurrency": 5
  },
  "FileSystem": {
    "LogsFolder": "/logs",
    "SupportedExtensions": [ ".log", ".txt" ]
  },
  "EventHub": {
    "FullyQualifiedNamespace": "YOUR_NAMESPACE.servicebus.windows.net",
    "EventHubName": "YOUR_EVENT_HUB_NAME",
    "ConsumerGroup": "$Default",
    "StartFromEarliest": false
  }
}
